# =============================================================================
# IoTFlow — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# For local Docker Compose development, defaults are already set in compose.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Secrets (change these in production!)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=iotflow_secret
REDIS_PASSWORD=iotflow_redis
GRAFANA_PASSWORD=admin

# ---------------------------------------------------------------------------
# MQTT Broker
# ---------------------------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=devices/+/events

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=iot.events.raw
KAFKA_TOPIC_DLQ=iot.events.dlq
KAFKA_CONSUMER_GROUP=iotflow-workers

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_EVENTS=100

# ---------------------------------------------------------------------------
# Retry Policy
# ---------------------------------------------------------------------------
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_MULTIPLIER=2.0
RETRY_MAX_DELAY_SECONDS=30.0

# ---------------------------------------------------------------------------
# Worker
# ---------------------------------------------------------------------------
MAX_CONCURRENT_TASKS=50
IDEMPOTENCY_TTL_SECONDS=259200
WORKER_ID=worker-1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
